# =============================================================================
# Castify — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in all values marked <CHANGE_ME>.
#
# Convention:
#   <CHANGE_ME>        — required, no safe default
#   <optional>         — optional, feature disabled if blank
#   value              — sane default for local development
#
# DO NOT commit .env to git.  Commit only this file (.env.example).
# =============================================================================


# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug


# =============================================================================
# INFRASTRUCTURE
# =============================================================================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=<CHANGE_ME>
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=castify
DATABASE_URL="postgresql://<CHANGE_ME>:<CHANGE_ME>@localhost:5432/castify?schema=public"
DIRECT_URL="postgresql://<CHANGE_ME>:<CHANGE_ME>@localhost:5432/castify?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<optional>
REDIS_URL="redis://localhost:6379"

# Kafka
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID=castify-local
KAFKA_GROUP_ID_PREFIX=castify
KAFKA_TOPIC_STREAM_STARTED=stream.started
KAFKA_TOPIC_STREAM_ENDED=stream.ended
KAFKA_TOPIC_VIDEO_SEGMENT_READY=video.segment.ready
KAFKA_TOPIC_CHAT_MESSAGE_SENT=chat.message.sent
KAFKA_TOPIC_VIEWER_JOINED=viewer.joined
KAFKA_TOPIC_VIEWER_LEFT=viewer.left
KAFKA_TOPIC_CLIP_REQUESTED=clip.requested

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9100
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=<CHANGE_ME>
MINIO_SECRET_KEY=<CHANGE_ME>
MINIO_REGION=us-east-1
S3_ENDPOINT="http://localhost:9100"
S3_ACCESS_KEY_ID=<CHANGE_ME>
S3_SECRET_ACCESS_KEY=<CHANGE_ME>
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET_HLS_SEGMENTS=hls-segments
S3_BUCKET_VOD_ARCHIVE=vod-archive
HLS_BASE_URL="http://localhost:8080/hls"

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9009
CLICKHOUSE_USER=<CHANGE_ME>
CLICKHOUSE_PASSWORD=<CHANGE_ME>
CLICKHOUSE_DATABASE=castify_analytics
CLICKHOUSE_URL="http://<CHANGE_ME>:<CHANGE_ME>@localhost:8123/castify_analytics"

# Nginx RTMP
NGINX_RTMP_HOST=localhost
NGINX_RTMP_PORT=1935
NGINX_HLS_HOST=localhost
NGINX_HLS_PORT=8080
NGINX_CONTROL_URL="http://localhost:8080/control"
NGINX_STAT_URL="http://localhost:8080/stat"


# =============================================================================
# APPLICATION SERVICES
# =============================================================================

# auth-service (port 3000)
# Owns: users, sessions, stream keys, entitlements, billing (Razorpay), OAuth
AUTH_SERVICE_PORT=3000
AUTH_SERVICE_HOST=localhost
PORT=3000
JWT_SECRET=<CHANGE_ME>
JWT_EXPIRES_IN="7d"
# Use one random value for auth-service, api-gateway, and rtmp-ingest.
INTERNAL_SECRET=<CHANGE_ME_WITH_A_RANDOM_32_PLUS_CHARACTER_SECRET>
# Browser origins allowed for credentialed requests (web app + local tooling)
CORS_ORIGINS="http://localhost:3200,http://127.0.0.1:3200,http://localhost:3000"
COOKIE_SECURE="false"
# COOKIE_DOMAIN=

# Object storage (auth-service thumbnails + VOD/HLS cleanup via MinIO)
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9100
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=<CHANGE_ME>
STORAGE_SECRET_KEY=<CHANGE_ME>
STORAGE_REGION=us-east-1
STORAGE_BUCKET=hls-segments
THUMBNAIL_PUBLIC_BASE="http://localhost:8080/minio/hls-segments"

# Public web origin (share/join links in the browser). Local default matches Next :3200
NEXT_PUBLIC_APP_URL="http://localhost:3200"

# OAuth (auth-service) — Google optional; use OAUTH_DEV_BYPASS=true for local mock
WEB_ORIGIN="http://localhost:3200"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/v1/auth/oauth/google/callback"
OAUTH_STATE_SECRET=""
OAUTH_DEV_BYPASS="true"
JWT_ACCESS_TOKEN_EXPIRES_IN="15m"
JWT_REFRESH_TOKEN_EXPIRES_IN="7d"
STREAM_KEY_LENGTH=32
BCRYPT_ROUNDS=10

# api-gateway (port 3100)
API_GATEWAY_PORT=3100
API_GATEWAY_HOST=localhost
INTERNAL_AUTH_URL="http://localhost:3000"
INTERNAL_RTMP_INGEST_URL="http://localhost:3001"
INTERNAL_TRANSCODING_URL="http://localhost:3002"
INTERNAL_HLS_PACKAGER_URL="http://localhost:3003"
INTERNAL_CHAT_URL="http://localhost:3004"
INTERNAL_PRESENCE_URL="http://localhost:3005"
INTERNAL_REACTION_URL="http://localhost:3006"
INTERNAL_NOTIFICATION_URL="http://localhost:3007"
INTERNAL_ANALYTICS_URL="http://localhost:3008"
INTERNAL_MODERATION_URL="http://localhost:3009"
INTERNAL_VOD_URL="http://localhost:3010"
INTERNAL_METADATA_URL="http://localhost:3011"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_CHAT_MAX=5
RATE_LIMIT_CHAT_WINDOW_MS=3000

# rtmp-ingest (port 3001)
RTMP_INGEST_PORT=3001
RTMP_INGEST_HOST=localhost
STREAM_INACTIVITY_TIMEOUT_SEC=30

# transcoding-service (port 3002)
TRANSCODING_SERVICE_PORT=3002
TRANSCODING_SERVICE_HOST=localhost
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
# ── Transcoding horizontal scale (local multi-process) ──────────────────────
# One live stream is always handled by ONE transcoder instance (Kafka key=streamId).
# Extra instances only help with MULTIPLE concurrent streams, not one 1440p encode.
# Example second worker:
#   cd apps/transcoding-service && PORT=3003 INSTANCE_ID=ts-b bun run dev
# Or: bun run dev:a  /  bun run dev:b
# Topics need partitions >= number of instances (create-kafka-topics.sh uses 3).
# INSTANCE_ID=ts-a
# PORT=3002
FFMPEG_PRESET=ultrafast
# Fallback only when stream.started has no qualities[]. Per-stream ladder (plan) wins.
# Full platform ladder so Pro 1080p/2k are not env-capped.
# For a single Mac + 1440p OBS, prefer fewer rungs e.g. 2k,720p,360p
FFMPEG_QUALITIES=2k,1080p,720p,480p,360p
TRANSCODE_QUALITIES=2k,1080p,720p,480p,360p
MAX_CONCURRENT_STREAMS=1
# hls-packager scale (optional 2nd process): PORT=3014 INSTANCE_ID=hp-b bun run dev
# MAX_CONCURRENT_UPLOADS=24
TRANSCODING_WORKER_CONCURRENCY=2

# hls-packager (port 3003)
HLS_PACKAGER_PORT=3003
HLS_PACKAGER_HOST=localhost
HLS_SEGMENT_DURATION_SEC=2
HLS_PLAYLIST_WINDOW_SIZE=5

# chat-service (port 3004)
# JWT_SECRET must match auth-service. Web uses GET /auth/chat-token then WS ?token=
CHAT_SERVICE_PORT=3004
CHAT_SERVICE_HOST=localhost
CHAT_REDIS_CHANNEL_PREFIX="castify:chat"
CHAT_HISTORY_LENGTH=100
CHAT_MAX_MESSAGE_LENGTH=500
CHAT_RATE_MAX=5
CHAT_RATE_WINDOW_MS=3000

# presence-service (port 3005)
PRESENCE_SERVICE_PORT=3005
PRESENCE_SERVICE_HOST=localhost
PRESENCE_REDIS_KEY_PREFIX="castify:presence"
PRESENCE_HEARTBEAT_INTERVAL_SEC=30
PRESENCE_KEY_TTL_SEC=60
PRESENCE_BROADCAST_INTERVAL_SEC=5

# reaction-service (port 3006)
REACTION_SERVICE_PORT=3006
REACTION_SERVICE_HOST=localhost
REACTION_BATCH_WINDOW_MS=100
REACTION_REDIS_KEY_PREFIX="castify:reactions"

# notification-service (port 3007)
NOTIFICATION_SERVICE_PORT=3007
NOTIFICATION_SERVICE_HOST=localhost
SMTP_HOST=<optional>
SMTP_PORT=587
SMTP_USER=<optional>
SMTP_PASS=<optional>
EMAIL_FROM="noreply@castify.dev"
RESEND_API_KEY=<optional>

# analytics-service (port 3008)
ANALYTICS_SERVICE_PORT=3008
ANALYTICS_SERVICE_HOST=localhost
ANALYTICS_FLUSH_INTERVAL_MS=5000
ANALYTICS_BATCH_MAX_SIZE=500

# moderation-service (port 3009)
MODERATION_SERVICE_PORT=3009
MODERATION_SERVICE_HOST=localhost
MODERATION_CACHE_TTL_SEC=300

# vod-service (port 3010)
VOD_SERVICE_PORT=3010
VOD_SERVICE_HOST=localhost
BULLMQ_QUEUE_VOD_STITCH=vod-stitch
BULLMQ_QUEUE_CLIP=clip-create
VOD_WORKER_CONCURRENCY=2
CLIP_WORKER_CONCURRENCY=4
BULLMQ_JOB_RETENTION_SEC=86400

# metadata-service (port 3011)
METADATA_SERVICE_PORT=3011
METADATA_SERVICE_HOST=localhost
METADATA_CACHE_TTL_SEC=60

# web / Next.js (port 3200)
# Browser calls auth-service directly for most REST (cookie JWT):
NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"
NEXT_PUBLIC_API_GATEWAY_URL="http://localhost:3100"
NEXT_PUBLIC_CHAT_API_URL="http://localhost:3004/api/v1/chat"
NEXT_PUBLIC_WS_CHAT_URL="ws://localhost:3004/ws"
NEXT_PUBLIC_WS_PRESENCE_URL="ws://localhost:3100/ws/presence"
NEXT_PUBLIC_WS_REACTIONS_URL="ws://localhost:3100/ws/reactions"
NEXT_PUBLIC_HLS_BASE_URL="http://localhost:8080/hls"
# Only public key id may ever be exposed to the browser (via /billing/subscribe response).
# Do NOT add RAZORPAY_KEY_SECRET or RAZORPAY_WEBHOOK_SECRET as NEXT_PUBLIC_*.

# =============================================================================
# BILLING — Razorpay Subscriptions (auth-service, INR)
# =============================================================================
# Plan gates (enforced server-side):
#   FREE  — max 720p, 1 stream key, 1 concurrent live
#   PRO   — full ladder to 2K, 5 keys, 5 concurrent lives (paid via Razorpay)
#   ENTERPRISE — higher limits; contact sales (no self-serve checkout)
#
# Setup (test mode):
#   1. Dashboard → Test Mode ON → Account & Settings → API Keys → generate
#   2. Paste KEY_ID (rzp_test_…) and KEY_SECRET below
#   3. Webhooks → Add endpoint:
#        URL: https://<your-tunnel>/api/v1/billing/webhooks/razorpay
#        Secret → RAZORPAY_WEBHOOK_SECRET
#      Events: subscription.authenticated, subscription.activated,
#              subscription.charged, subscription.pending, subscription.halted,
#              subscription.paused, subscription.resumed, subscription.cancelled,
#              subscription.completed
#   4. Optional: create a monthly Plan in Dashboard (₹999) and set RAZORPAY_PRO_PLAN_ID
#      OR leave blank — first subscribe auto-creates a plan via API
#   5. Seed helper: cd apps/auth-service && bun run scripts/seed-razorpay-pro-plan.ts
#   6. Local tunnel example: cloudflared / ngrok http 3000
#
# Security:
#   - KEY_SECRET + WEBHOOK_SECRET stay on the server only
#   - Checkout signature verified as HMAC(payment_id|subscription_id)
#   - Webhook uses raw body + X-Razorpay-Signature
# =============================================================================
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="<CHANGE_ME>"
RAZORPAY_WEBHOOK_SECRET="<CHANGE_ME>"
# REQUIRED if plans.create returns 401 (common until Subscriptions product is fully enabled):
# Dashboard (Test Mode) → Subscriptions → Plans → Create monthly plan → copy plan_xxxx
# With this set, auth-service never calls plans.create — only subscriptions.create.
RAZORPAY_PRO_PLAN_ID="plan_xxxxxxxx"
BILLING_CURRENCY="INR"
# Amount in paise (99900 = ₹999.00 per month)
BILLING_PRO_AMOUNT_PAISE=99900
# Max billing cycles when creating a subscription (120 ≈ 10 years monthly)
BILLING_SUBSCRIPTION_TOTAL_COUNT=120


# =============================================================================
# OBSERVABILITY
# =============================================================================
METRICS_ENABLED=false
METRICS_PORT=9090


# =============================================================================
# CORS (duplicate note)
# =============================================================================
# Primary CORS_ORIGINS is under auth-service above. Keep both web (3200) and
# auth (3000) origins if any service re-reads this block alone.
# CORS_ORIGINS="http://localhost:3200,http://127.0.0.1:3200,http://localhost:3000"
