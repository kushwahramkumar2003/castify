# =============================================================================
# chat-service — environment template
# =============================================================================
# Copy to .env and fill values:
#   cp .env.example .env
#
# Bun loads apps/chat-service/.env when you run: bun run dev
# JWT_SECRET must match auth-service so castify_token cookies validate.
# DATABASE_URL is required for bans, blocked words, timeouts, and stream access.
# =============================================================================

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3004
LOG_LEVEL=info

# ── Auth (must match auth-service exactly) ───────────────────────────────────
# Min 32 characters. Same secret that signs castify_token cookies / JWTs.
# Web calls GET /auth/chat-token (cookie → short JWT), then connects with
# Authorization: Bearer <token> and ws://…/ws?token=<token>.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ── Database (Postgres via @castify/db) ──────────────────────────────────────
DATABASE_URL=postgresql://castify:castify@localhost:5432/castify?schema=public
# Optional alternative if your setup uses a direct (non-pooled) URL:
# DIRECT_URL=postgresql://castify:castify@localhost:5432/castify?schema=public

# ── CORS (browser origin for REST + cookie credentials) ──────────────────────
# Comma-separated. Web app default port is 3200.
CORS_ORIGINS=http://localhost:3200,http://127.0.0.1:3200

# ── Chat behaviour ───────────────────────────────────────────────────────────
# Ring-buffer size of in-memory messages kept per stream room
CHAT_HISTORY_LENGTH=100
# Max characters per chat message
CHAT_MAX_MESSAGE_LENGTH=500
# Max messages per user per window (reactions use 2× this)
CHAT_RATE_MAX=5
# Rate-limit window in milliseconds
CHAT_RATE_WINDOW_MS=3000
