{
  "name": "@castify/transcoding-service",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:a": "PORT=3002 INSTANCE_ID=ts-a bun run --watch src/index.ts",
    "dev:b": "PORT=3003 INSTANCE_ID=ts-b bun run --watch src/index.ts",
    "dev:c": "PORT=3005 INSTANCE_ID=ts-c bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@castify/kafka": "workspace:*",
    "@castify/logger": "workspace:*",
    "@castify/types": "workspace:*",
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "minio": "^8.0.7",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
